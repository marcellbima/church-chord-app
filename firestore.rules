// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Songs: siapa saja bisa baca, hanya admin (authenticated) yang bisa tulis
    match /songs/{songId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Chords subcollection: sama dengan songs
      match /chords/{chordId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
